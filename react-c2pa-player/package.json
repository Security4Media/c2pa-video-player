{
    "name": "react-c2pa-player",
    "version": "1.0.0",
    "type": "module",
    "description": "EBU C2PA Monolithic player",
    "scripts": {
        "dev": "concurrently -n http,vite -c blue,green vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "start": "http-server -p 9000 -c-1 -d false -g"
        
    },
    "dependencies": {
        "@contentauth/c2pa-web": "^0.5.6",
        "http-server": "^14.1.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "video.js": "^8.3.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/video.js": "^7.3.58",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^9.1.2",
        "typescript": "^5.3.3",
        "vite": "^5.1.0"
    }
}