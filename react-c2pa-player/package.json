{
    "name": "react-c2pa-player",
    "version": "1.0.0",
    "private": true,
    "description": "EBU C2PA Monolithic player",
    "homepage": "https://Security4Media.github.io/c2pa-player/",
    "scripts": {
        "dev": "concurrently -n http,vite -c blue,green vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "start": "http-server -p 9000 -c-1 -d false -g",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build"
    },
    "dependencies": {
        "@contentauth/c2pa-web": "^0.5.6",
        "http-server": "^14.1.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "video.js": "^8.3.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/video.js": "^7.3.58",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^9.1.2",
        "gh-pages": "^6.3.0",
        "typescript": "^5.3.3",
        "vite": "^5.1.0"
    }
}
