# Environment variables for React C2PA Player Docker deployment
# Copy this file to .env and customize as needed

# Port to expose the application (default: 8080)
# DOCKER_PORT=8080

# Node environment (production is default in Docker)
# NODE_ENV=production

# Future configuration options can be added here
# Examples:
# API_URL=https://api.example.com
# LOG_LEVEL=info
